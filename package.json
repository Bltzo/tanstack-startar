{
  "name": "tanstack-template",
  "version": "0.0.0",
  "description": "TanStack Template",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env vite dev",
    "build": "pnpm with-env vite build",
    "start": "pnpm with-env node .output/server/index.mjs",
    "lint": "pnpm lint:i18n && oxlint --type-aware",
    "test": "pnpm with-env vitest",
    "coverage": "pnpm with-env vitest run --coverage",
    "format:write": "oxfmt --write",
    "format": "oxfmt --check",
    "type-check": "tsc --noEmit",
    "verify": "pnpm format:write && pnpm lint && pnpm type-check",
    "with-env": "dotenv -e .env --",
    "prepare": "node .husky/install.mjs && tsx scripts/setup.ts",
    "test:e2e:install": "playwright install --with-deps",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config=playwright.config.ts",
    "lint:i18n": "pnpm dlx @inlang/cli lint --project ./project.inlang --languageTags en,ar",
    "postinstall": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/nitro-v2-vite-plugin": "^1.154.9",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-router-ssr-query": "^1.166.10",
    "@tanstack/react-start": "^1.167.13",
    "@tanstack/router-core": "^1.168.7",
    "@tanstack/router-valibot-adapter": "^1.81.5",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.3.1",
    "valibot-env": "^1.0.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@inlang/paraglide-js": "^2.15.1",
    "@playwright/test": "^1.58.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-form-devtools": "^0.2.19",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/vite-config": "^0.5.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "dotenv-cli": "^11.0.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0",
    "vitest-dom": "^0.1.1"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --fix"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msw"
    ]
  }
}
