{
  "name": "tanstack-template",
  "version": "0.0.0",
  "description": "TanStack Template",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env vite dev",
    "build": "pnpm with-env vite build",
    "start": "pnpm with-env node .output/server/index.mjs",
    "lint": "pnpm lint:i18n && oxlint --type-aware",
    "test": "pnpm with-env vitest",
    "coverage": "pnpm with-env vitest run --coverage",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "type-check": "tsc --noEmit",
    "verify": "pnpm format:write && pnpm lint && pnpm type-check",
    "with-env": "dotenv -e .env --",
    "prepare": "node .husky/install.mjs && tsx scripts/setup.ts",
    "test:e2e:install": "playwright install --with-deps",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --ui --config=playwright.config.ts",
    "lint:i18n": "pnpm dlx @inlang/cli lint --project ./project.inlang --languageTags en,ar",
    "postinstall": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/nitro-v2-vite-plugin": "^1.133.19",
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@tanstack/react-router": "^1.133.32",
    "@tanstack/react-router-ssr-query": "^1.133.33",
    "@tanstack/react-start": "^1.133.34",
    "@tanstack/router-core": "^1.133.28",
    "@tanstack/router-valibot-adapter": "^1.81.5",
    "axios": "^1.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.548.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.65.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.3",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.1.0",
    "valibot-env": "^1.0.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@inlang/paraglide-js": "^2.4.0",
    "@playwright/test": "^1.56.1",
    "@tanstack/react-router-devtools": "^1.133.34",
    "@tanstack/vite-config": "^0.4.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/browser": "^4.0.4",
    "@vitest/ui": "^4.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^10.0.0",
    "happy-dom": "^20.0.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "oxlint": "^1.24.0",
    "oxlint-tsgolint": "^0.3.0",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^4.1.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.4",
    "vitest-browser-react": "^2.0.2",
    "vitest-dom": "^0.1.1"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.{js,jsx,ts,tsx}": [
      "oxlint --type-aware --fix"
    ]
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "msw"
    ]
  }
}
