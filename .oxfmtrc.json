{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortTailwindcss": {
    "stylesheet": "./src/styles.css",
    "functions": ["cn", "cva"]
  },
  "sortImports": {
    "groups": [
      "type", // <TYPES>
      "external", // React & third-party modules
      "internal", // @project-q packages
      "subpath", // @project-q subpaths
      "parent", // ../ relative imports
      "sibling", // ./ relative imports
      "index", // ./index files
      "style", // CSS / style imports
      "unknown" // fallback
    ],
    "sortSpecifiers": true,
    "separateGroups": true
  },
  "importOrderParserPlugins": ["typescript", "jsx", "decorators-legacy"],
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/build",
    "**/public",
    "pnpm-lock.yaml",
    "**/generated",
    "**/routeTree.gen.ts",
    "src/i18n",
    ".output",
    ".nitro",
    "dist",
    ".amplify-hosting",
    ".turbo",
    "project.inlang/README.md",
    "project.inlang/.meta.json"
  ]
}
